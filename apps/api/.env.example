DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/neondb?sslmode=require
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# Required in production for Calendar/Gmail OAuth token exchange (enforced at boot).
GOOGLE_CLIENT_SECRET=
# Sign in with Apple — native iOS audience (defaults to com.recall.app)
# APPLE_CLIENT_ID=com.recall.app
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# LLM — all models route through OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Optional speech-to-text model on OpenRouter (default: openai/whisper-1)
# SPEECH_TRANSCRIPTION_MODEL=openai/whisper-1
# DEEPSEEK_API_KEY=  # optional legacy; not used by default catalog

TAVILY_API_KEY=

# Web search (Tavily primary — https://tavily.com; DuckDuckGo fallback when key unset)
WEB_SEARCH_ENABLED=true
WEB_SEARCH_CLASSIFIER_ENABLED=true
WEB_SEARCH_FALLBACK_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5

DAILY_TOKEN_LIMIT=30000
DAILY_TOKEN_LIMIT_PRO=500000
MAX_OUTPUT_TOKENS=1200
# Abort hung chat streams after this many seconds (WebSocket path).
# CHAT_STREAM_TIMEOUT_SECONDS=180
# Abort hung background (non-streaming) LLM calls after this many seconds.
# BACKGROUND_LLM_TIMEOUT_SECONDS=60
# Global REST rate limit per authenticated user or IP (health/webhooks excluded). 0 disables.
# REST_RATE_LIMIT_PER_MINUTE=240
RECENT_MESSAGE_WINDOW=20

# RevenueCat (Project → API keys → Secret API key; Webhooks → Authorization header)
# REVENUECAT_SECRET_KEY=
# REVENUECAT_WEBHOOK_AUTH=
# REVENUECAT_ENTITLEMENT_ID=pro

# Push notifications (Expo Push API — no extra key; requires device tokens from app)
PUSH_ENABLED=true
PUSH_LEARNING_HOUR=9

# Optional MCP pre-stream tool round (web search + calendar write hints via adapters)
# MCP_TOOLS_ENABLED=false

# SymPy symbolic math (solve, geometry, graph sampling — injected before LLM stream)
# MATH_TOOLS_ENABLED=true
# MATH_MAX_EXPR_LENGTH=256
# MATH_GRAPH_MAX_POINTS=300

# Fernet key that encrypts OAuth refresh tokens (Calendar/Gmail) at rest.
# Required in production. Generate one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OAUTH_TOKEN_ENCRYPTION_KEY=

# CORS — comma-separated explicit origins. Required in production (the app
# rejects an empty value there). For the mobile app only, the API URL is set
# per-device in apps/mobile/.env and doesn't need to be listed here.
CORS_ORIGINS=https://app.recall.app

# Attachments storage. STORAGE_BACKEND=local (default) writes to disk; set to
# r2 to use Cloudflare R2 (S3-compatible) — the client uploads/downloads via
# presigned URLs so blobs never touch the API. R2 creds come from a Cloudflare
# API token with R2 read+write on the bucket.
# STORAGE_BACKEND=local
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=recall-attachments
# R2_ENDPOINT=  # optional; derived as https://<account_id>.r2.cloudflarestorage.com

# Optional error reporting (leave empty to disable)
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Transactional email (Resend — https://resend.com)
# RESEND_API_KEY=
# EMAIL_FROM=Recall <noreply@yourdomain.com>

# Dev placeholders (set ENVIRONMENT=production and both flags false in production)
DEV_AUTH_ENABLED=true
MOCK_LLM_ENABLED=true
ENVIRONMENT=development
# Comma-separated user UUIDs allowed to call /admin/* when DEV_AUTH_ENABLED=true
# ADMIN_USER_IDS=

# Process role: all (local dev — HTTP + worker in one process), api (HTTP/WS only),
# worker (background jobs only — use `python -m app.worker_main`).
# PROCESS_ROLE=all
# SPEECH_TRANSCRIPTION_ENABLED=true

# Neon:  https://neon.tech  → Connection string → use asyncpg URL above
# Upstash: https://upstash.com → Redis → REST or redis URL (rediss://...)
