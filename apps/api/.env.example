DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/neondb?sslmode=require
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=10080

DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

DAILY_TOKEN_LIMIT=500000
MAX_OUTPUT_TOKENS=1200
RECENT_MESSAGE_WINDOW=20

SENTRY_DSN=

# Dev placeholders (set DEV_AUTH_ENABLED=false in production)
DEV_AUTH_ENABLED=true
MOCK_LLM_ENABLED=true
ENVIRONMENT=development

# Neon:  https://neon.tech  → Connection string → use asyncpg URL above
# Upstash: https://upstash.com → Redis → REST or redis URL (rediss://...)
