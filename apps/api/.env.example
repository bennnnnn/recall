DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/neondb?sslmode=require
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=10080

# LLM — all models route through OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=  # optional legacy; not used by default catalog

TAVILY_API_KEY=

# Web search (Tavily primary — https://tavily.com; DuckDuckGo fallback when key unset)
WEB_SEARCH_ENABLED=true
WEB_SEARCH_FALLBACK_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5

DAILY_TOKEN_LIMIT=30000
DAILY_TOKEN_LIMIT_PRO=500000
MAX_OUTPUT_TOKENS=1200
RECENT_MESSAGE_WINDOW=20

# RevenueCat (Project → API keys → Secret API key; Webhooks → Authorization header)
# REVENUECAT_SECRET_KEY=
# REVENUECAT_WEBHOOK_AUTH=
# REVENUECAT_ENTITLEMENT_ID=pro

# Push notifications (Expo Push API — no extra key; requires device tokens from app)
PUSH_ENABLED=true
PUSH_LEARNING_HOUR=9

# Optional MCP pre-stream tool round (web search + calendar write hints via adapters)
# MCP_TOOLS_ENABLED=false

# SymPy symbolic math (solve, geometry, graph sampling — injected before LLM stream)
# MATH_TOOLS_ENABLED=true
# MATH_MAX_EXPR_LENGTH=256
# MATH_GRAPH_MAX_POINTS=300

SENTRY_DSN=

# Dev placeholders (set DEV_AUTH_ENABLED=false in production)
DEV_AUTH_ENABLED=true
MOCK_LLM_ENABLED=true
ENVIRONMENT=development

# Neon:  https://neon.tech  → Connection string → use asyncpg URL above
# Upstash: https://upstash.com → Redis → REST or redis URL (rediss://...)
