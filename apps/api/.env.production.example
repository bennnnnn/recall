# Recall API — production secrets template (copy → .env.production, fill values).
# Import to Fly: ../../scripts/fly-secrets-import.sh
# Generate crypto secrets: ../../scripts/generate-prod-secrets.sh

ENVIRONMENT=production
DEV_AUTH_ENABLED=false
MOCK_LLM_ENABLED=false
PROCESS_ROLE=api

# --- Required (app will not boot without these) ---
JWT_SECRET=
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/neondb?sslmode=require
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OPENROUTER_API_KEY=
OAUTH_TOKEN_ENCRYPTION_KEY=
CORS_ORIGINS=https://app.recall.app
REVENUECAT_WEBHOOK_AUTH=

# --- R2 attachments (required in production) ---
STORAGE_BACKEND=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=recall-attachments

# --- Apple Sign-In (iOS; default bundle audience) ---
APPLE_CLIENT_ID=com.recall.app

# --- Recommended ---
SENTRY_DSN=
TAVILY_API_KEY=
REVENUECAT_SECRET_KEY=

# --- Optional tuning ---
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30
DAILY_TOKEN_LIMIT=100000
DAILY_TOKEN_LIMIT_PRO=500000
RECENT_MESSAGE_WINDOW=20
WEB_SEARCH_ENABLED=true
PUSH_ENABLED=true
