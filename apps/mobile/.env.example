EXPO_PUBLIC_API_URL=http://localhost:8000
# Required in EAS production/preview builds (set in Expo dashboard → Secrets, not localhost).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
# Optional dev login bypass (backend DEV_AUTH_ENABLED must also be true)
EXPO_PUBLIC_DEV_AUTH_ENABLED=false
# Remote push — UUID from https://expo.dev (Project → Project settings). Run: npx eas init
# EXPO_PUBLIC_EAS_PROJECT_ID=
# RevenueCat public SDK keys (Project → API keys → App-specific keys)
# EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
# EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
